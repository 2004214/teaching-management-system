client/dist/
client/dist-ssr/

# ===== 日志 =====
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== IDE / OS =====
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

