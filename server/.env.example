# ===== 服务器 =====
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ===== PostgreSQL 数据库 =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teaching_management
DB_USER=postgres
DB_PASSWORD=change_me_in_local
DB_DIALECT=postgres
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_LOGGING=false

# ===== JWT 密钥 (RS256, 相对 server/ 目录) =====
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRES_IN=7d
JWT_ISSUER=teaching-management-system
JWT_AUDIENCE=teaching-management-client

# ===== 字段级加密 (AES-256-GCM, 32 字节 hex = 64 字符) =====
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=replace_with_64_hex_chars_for_field_encryption_key_placeholder_00

# ===== .env 主密钥 (用于加密 .env 文件本身) =====
# 生成: node server/bin/env-crypt.js genkey
MASTER_KEY=replace_with_64_hex_chars_for_master_encryption_key_placeholder_0000

# ===== 上传目录 =====
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=10485760
