# ===== 服务器 =====
PORT=8080
NODE_ENV=development
# 多个前端来源用逗号分隔, 支持通配后缀 *.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ===== PostgreSQL 数据库 =====
# 方式 A: 本地开发, 分字段填写
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teaching_management
DB_USER=postgres
DB_PASSWORD=change_me_in_local
DB_DIALECT=postgres
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_LOGGING=false
# 是否强制启用 SSL (production + DATABASE_URL 时会自动启用)
DB_SSL=false

# 方式 B: 云端部署 (Neon / Supabase / Render PG), 用单一连接串, 上面 DB_* 都会被忽略
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ===== JWT 密钥 (RS256) =====
# 方式 A: 本地文件 (相对 server/ 目录, 首次启动自动生成)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# 方式 B: 云端部署 (Render 免费版文件系统临时), 用 base64 编码放到 env
# 生成命令: npm run keys:genb64
# JWT_PRIVATE_KEY_B64=...
# JWT_PUBLIC_KEY_B64=...

JWT_EXPIRES_IN=7d
JWT_ISSUER=teaching-management-system
JWT_AUDIENCE=teaching-management-client

# ===== 字段级加密 (AES-256-GCM, 32 字节 hex = 64 字符) =====
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=replace_with_64_hex_chars_for_field_encryption_key_placeholder_00

# ===== .env 主密钥 (用于加密 .env 文件本身) =====
# 生成: node server/bin/env-crypt.js genkey
MASTER_KEY=replace_with_64_hex_chars_for_master_encryption_key_placeholder_0000

# ===== 上传目录 =====
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=10485760
