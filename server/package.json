{
  "name": "teaching-management-system-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.17.0 <21"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "env:genkey": "node bin/env-crypt.js genkey",
    "env:encrypt": "node bin/env-crypt.js encrypt",
    "env:decrypt": "node bin/env-crypt.js decrypt",
    "keys:genb64": "node -e \"import('./utils/keys.js').then(m=>{const r=m.generateKeyPairBase64();console.log('JWT_PRIVATE_KEY_B64='+r.privateKeyB64);console.log('JWT_PUBLIC_KEY_B64='+r.publicKeyB64)})\""
  },
  "dependencies": {
    "argon2": "^0.31.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
